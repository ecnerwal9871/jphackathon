        "[resourceId('Microsoft.Communication/emailServices/domains', format('acs-email-{0}', parameters('baseName')), 'AzureManagedDomain')]",
        "[resourceId('Microsoft.Insights/components', format('appi-{0}', parameters('baseName')))]",
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', format('cosmos-{0}', parameters('baseName')))]",
        "[resourceId('Microsoft.KeyVault/vaults', format('kv-{0}', parameters('baseName')))]",
