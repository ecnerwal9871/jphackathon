# Copy this file to .env.local for local development
# These are populated automatically in Azure SWA via app settings

# Azure Application Insights (get from Azure Portal → appi-flightbuddy → Connection String)
NEXT_PUBLIC_APPINSIGHTS_CONNECTION_STRING=

# For local dev only — in production these come from SWA managed identity / app settings
COSMOS_ENDPOINT=
ACS_ENDPOINT=
ACS_SENDER_ADDRESS=
APP_URL=http://localhost:3000
